---
/**
 * index.astro — Main landing page.
 * Assembles all sections in order following the Obsidian Pulse design.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/nav/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import TechStack from '../components/sections/TechStack.astro';
import ArchitecturalPillars from '../components/sections/ArchitecturalPillars.astro';
import RecentBuilds from '../components/sections/RecentBuilds.astro';
import Certifications from '../components/sections/Certifications.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import ContactDialog from '../components/sections/ContactDialog.astro';
import StatsBar from '../components/sections/StatsBar.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout>
  <Navbar />

  <main id="main-content" class="pb-20">
    <Hero />
    <StatsBar />
    <TechStack />
    <ArchitecturalPillars />
    <RecentBuilds />
    <Certifications />
    <CallToAction />
  </main>

  <Footer />
  <ContactDialog />
</BaseLayout>
