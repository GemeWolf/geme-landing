---
/**
 * PillarCard — architectural pillar card.
 * Transparent bg with wine-red border glow on hover.
 */
import type { PillarItem } from '../../data/types';
import Icon from './Icon.astro';

interface Props {
  item: PillarItem;
}

const { item } = Astro.props;
---

<div class="bg-transparent p-5 rounded-lg border border-primary-container/30 hover:shadow-[0_0_40px_rgba(150,53,71,0.15)] transition-all group">
  <Icon name={item.icon} class="w-9 h-9 text-primary-container mb-6 block group-hover:scale-110 transition-transform" />
  <h3 class="font-headline text-lg md:text-xl font-bold text-on-surface mb-3">{item.title}</h3>
  <p class="font-body text-xs md:text-sm text-on-surface-variant/70 leading-relaxed">{item.description}</p>
</div>
