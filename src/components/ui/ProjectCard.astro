---
/**
 * ProjectCard — project showcase card with alternating layout.
 * Uses 12-column grid: 7-col image + 5-col text, alternating.
 */
import type { ProjectItem } from '../../data/types';
import Badge from './Badge.astro';
import Icon from './Icon.astro';

interface Props {
  item: ProjectItem;
}

const { item } = Astro.props;
const isImageRight = item.layout === 'image-right';
const plainImage = item.plainImage === true;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-start">
  {/* Image — default: framed + overlay + enhance; plainImage: solo img */}
  <div
    class:list={[
      'lg:col-span-7',
      !plainImage && 'group',
      isImageRight && 'order-1 lg:order-2',
    ]}
  >
    {item.imageUrl && plainImage ? (
      <img
        src={item.imageUrl}
        alt={`Project ${item.title}`}
        loading="lazy"
        decoding="async"
        class="w-full aspect-[16/9] object-cover rounded-[8px]"
      />
    ) : (
      <div
        class="relative w-full aspect-[16/9] overflow-hidden rounded-[8px] border border-outline-variant/20 bg-surface-container shadow-2xl"
      >
        {item.imageUrl ? (
          <>
            <img
              src={item.imageUrl}
              alt={`Project ${item.title}`}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover transition-all duration-700 group-hover:scale-105 project-img-enhance"
            />
            <div
              class="pointer-events-none absolute inset-0 z-[1] bg-[rgba(0,0,0,0.3)]"
              aria-hidden="true"
            />
          </>
        ) : (
          <div class="absolute inset-0 flex items-center justify-center bg-surface-container">
            <Icon name={item.iconFallback || 'terminal'} class="w-16 h-16 text-primary-container" />
          </div>
        )}
      </div>
    )}
  </div>

  {/* Text */}
  <div
    class:list={[
      'lg:col-span-5',
      isImageRight && 'order-2 lg:order-1',
    ]}
  >
    <span class="font-label text-[10px] tracking-widest text-primary font-bold uppercase mb-3 block">
      {item.period} / {item.role}
    </span>
    <h3 class="font-headline text-3xl font-bold text-on-surface mb-4">{item.title}</h3>
    <p class="font-body text-base text-on-surface-variant mb-6 leading-relaxed">
      {item.description}
    </p>
    <div class="flex flex-wrap gap-2 mb-8">
      {item.technologies.map((tech) => (
        <Badge>{tech}</Badge>
      ))}
    </div>
  </div>
</div>
