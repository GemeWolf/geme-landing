---
/**
 * RecentBuilds — project showcase with alternating layouts.
 * 3 projects displayed in a 12-column grid with image/text alternation.
 */
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { recentBuilds } from '../../data/projects';
import ProjectCard from '../ui/ProjectCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="projects" class="px-6 md:px-24 mb-24">
  <!-- Section title with decorative lines -->
  <div class="flex items-center gap-3 mb-12">
    <div class="h-px bg-outline-variant/30 flex-grow"></div>
    <h2 class="font-headline text-xl font-bold uppercase tracking-widest text-primary-container">
      {t('projects.title')}
    </h2>
    <div class="h-px bg-outline-variant/30 flex-grow"></div>
  </div>

  <div class="space-y-20 md:space-y-32">
    {recentBuilds[lang].map((project) => (
      <ProjectCard item={project} />
    ))}
  </div>
</section>
