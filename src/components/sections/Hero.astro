---
/**
 * Hero — main landing section.
 * Massive "GEME" headline with glow, particle/dot silhouette canvas,
 * status badge, and two CTAs.
 */
import Button from '../ui/Button.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="px-6 md:px-24 mb-24 pt-28 pb-8 relative overflow-hidden">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
    <!-- Text Content -->
    <div class="lg:max-w-2xl">
      <p class="font-label text-[10px] md:text-xs tracking-[0.4em] text-primary uppercase mb-2">
        {t('hero.name')}
      </p>
      <h1 class="font-headline text-[clamp(4.5rem,15vw,8rem)] font-bold text-primary-container leading-[0.8] tracking-tighter text-glow mb-4">
        GEME
      </h1>
      <p class="font-headline text-lg md:text-4xl text-on-surface-variant font-light tracking-tight mb-6 leading-[1.3] max-w-md">
        {t('hero.role')}
        <span class="text-primary font-medium">{t('hero.roleHighlight')}</span>
      </p>
      <p class="font-body text-base text-on-surface-variant/80 max-w-xl mb-8 leading-relaxed">
        {t('hero.description')}
      </p>
      <div class="flex flex-wrap gap-3">
        <Button variant="primary" href="#projects">{t('hero.cta.primary')}</Button>
        <Button variant="secondary" data-contact-trigger>{t('hero.cta.secondary')}</Button>
      </div>

      <!-- Now Status Badge -->
      <div class="mt-4">
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full uppercase tracking-[0.08em] text-[0.7rem]"
          style="background: rgba(150, 53, 71, 0.15); border: 1px solid rgba(150, 53, 71, 0.3); color: #963547;">
          <span class="now-dot inline-block w-1.5 h-1.5 rounded-full bg-amber-400"></span>
          {t('hero.now')}
        </span>
      </div>

      <!-- Live Timezone Widget -->
      <div class="mt-3 flex items-center gap-2">
        <span class="live-dot inline-block w-1.5 h-1.5 rounded-full bg-green-400"></span>
        <span id="hero-clock" class="uppercase tracking-[0.1em]"
          style="font-size: 0.75rem; color: rgba(247, 218, 243, 0.5);">
          CDMX — --:-- --
        </span>
      </div>
    </div>

    <!-- Profile Photo — particle silhouette -->
    <div class="flex justify-center relative mt-12 lg:mt-0">
      <div class="relative w-80 h-80 md:w-96 md:h-96 lg:w-[420px] lg:h-[420px]">
        <!-- Particle canvas -->
        <canvas
          id="hero-particle-canvas"
          class="relative z-10 w-full h-full"
          style="display: block;"
          aria-label="GEME — Daniel López Talamantes, Backend Engineer & DevOps Architect"
        ></canvas>
        <!-- Status Badge -->
        <div class="absolute -bottom-2 -right-2 md:-bottom-4 md:-right-4 bg-surface-container p-3 md:p-4 rounded-sm border border-outline-variant/20 shadow-2xl z-20">
          <span class="block font-label text-[8px] md:text-[10px] tracking-widest text-primary-container uppercase mb-1">{t('hero.status.label')}</span>
          <span class="block font-headline text-[10px] md:text-xs font-bold text-primary">{t('hero.status.value')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .live-dot {
    animation: pulse-green 2s ease-in-out infinite;
  }
  .now-dot {
    animation: pulse-amber 2s ease-in-out infinite;
  }
  @keyframes pulse-green {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.6); }
    50% { opacity: 0.6; box-shadow: 0 0 0 4px rgba(74, 222, 128, 0); }
  }
  @keyframes pulse-amber {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.6); }
    50% { opacity: 0.6; box-shadow: 0 0 0 4px rgba(251, 191, 36, 0); }
  }
</style>

<script>
  // ── Clock ──────────────────────────────────────────────────────────────────
  function updateClock() {
    const el = document.getElementById('hero-clock');
    if (!el) return;
    const now = new Date().toLocaleTimeString('en-US', {
      timeZone: 'America/Mexico_City',
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
    });
    el.textContent = `CDMX — ${now}`;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ── Particle silhouette ────────────────────────────────────────────────────
  (function initParticles() {
    const canvas = document.getElementById('hero-particle-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Match canvas resolution to its CSS size
    const rect = canvas.getBoundingClientRect();
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const W = rect.width  || 420;
    const H = rect.height || 420;
    canvas.width  = W * DPR;
    canvas.height = H * DPR;
    ctx.scale(DPR, DPR);

    const DOT_RADIUS = 2.5;
    const GAP        = 5;   // sampling step (dot center to center)

    // Particle data: [x, y, baseY, speed, phase]
    type Particle = { x: number; y: number; baseY: number; speed: number; phase: number; alpha: number };
    let particles: Particle[] = [];
    let animFrameId: number;

    function buildParticles(imgW: number, imgH: number, pixels: Uint8ClampedArray) {
      particles = [];

      // Scale factor: fit image into canvas
      const scale = Math.min(W / imgW, H / imgH);
      const drawW = imgW * scale;
      const drawH = imgH * scale;
      const offX  = (W - drawW) / 2;
      const offY  = (H - drawH) / 2;

      for (let py = GAP / 2; py < H; py += GAP) {
        for (let px = GAP / 2; px < W; px += GAP) {
          // Map canvas pixel → image pixel
          const imgX = Math.floor((px - offX) / scale);
          const imgY = Math.floor((py - offY) / scale);

          if (imgX < 0 || imgX >= imgW || imgY < 0 || imgY >= imgH) continue;

          const idx   = (imgY * imgW + imgX) * 4;
          const alpha = pixels[idx + 3];

          if (alpha < 40) continue; // skip transparent pixels

          // Depth: dots near top are slightly dimmer, max 0.85
          const depthAlpha = 0.25 + (py / H) * 0.60;

          particles.push({
            x:      px,
            y:      py,
            baseY:  py,
            speed:  0.3 + Math.random() * 0.5,
            phase:  Math.random() * Math.PI * 2,
            alpha:  depthAlpha,
          });
        }
      }
    }

    function draw(ts: number) {
      ctx.clearRect(0, 0, W, H);

      for (const p of particles) {
        // Slow floating: ±3px vertical oscillation
        const drift = Math.sin(ts * 0.001 * p.speed + p.phase) * 3;
        const y     = p.baseY + drift;

        // Color: wine red gradient by depth (top = dim, bottom = vivid)
        const r = 150, g = 53, b = 71;
        ctx.beginPath();
        ctx.arc(p.x, y, DOT_RADIUS, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${p.alpha})`;
        ctx.fill();
      }

      animFrameId = requestAnimationFrame(draw);
    }

    // Load the source image off-screen to sample pixels
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.src = '/gemewolf-removebg-preview.png';

    img.onload = () => {
      // Draw into an off-screen canvas to read pixel data
      const off    = document.createElement('canvas');
      off.width    = img.naturalWidth;
      off.height   = img.naturalHeight;
      const offCtx = off.getContext('2d')!;
      offCtx.drawImage(img, 0, 0);

      const { data } = offCtx.getImageData(0, 0, off.width, off.height);
      buildParticles(off.width, off.height, data);

      if (animFrameId) cancelAnimationFrame(animFrameId);
      requestAnimationFrame(draw);
    };

    img.onerror = () => {
      // Fallback: draw a simple circle of dots if image fails
      for (let angle = 0; angle < Math.PI * 2; angle += 0.05) {
        const r = W * 0.4;
        particles.push({
          x: W / 2 + Math.cos(angle) * r,
          y: H / 2 + Math.sin(angle) * r,
          baseY: H / 2 + Math.sin(angle) * r,
          speed: 0.4 + Math.random() * 0.4,
          phase: Math.random() * Math.PI * 2,
          alpha: 0.6,
        });
      }
      requestAnimationFrame(draw);
    };
  })();
</script>
